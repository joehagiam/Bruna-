<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BRUNA YR | Atelier de Moda, Joyería y Belleza</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #C5A059; /* Tu dorado oficial */
            --luxury-black: #1A1A1A;
            --pure-white: #FFFFFF;
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--pure-white); 
            color: var(--luxury-black);
            -webkit-font-smoothing: antialiased;
        }
        h1, h2, h3, h4, .font-serif { 
            font-family: 'Cormorant Garamond', serif; 
            font-weight: 400;
        }
        .text-gold { color: var(--gold); }
        .bg-gold { background-color: var(--gold); }
        .border-gold { border-color: var(--gold); }
        
        /* Animaciones suaves */
        .fade-in { animation: fadeIn 1.2s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Efecto Hover Premium en Imágenes */
        .product-card img { transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1); }
        .product-card:hover img { transform: scale(1.03); }
        
        /* Modal de Administrador - Diseño Sleek */
        .admin-modal { display: none; background: rgba(0,0,0,0.9); backdrop-filter: blur(8px); }
        .admin-modal.active { display: flex; }
        .admin-input { background: #F9F9F9; border: 1px solid #EEE; padding: 1rem; border-radius: 2px; width: 100%; }
    </style>
</head>
<body class="overflow-x-hidden">

    <nav class="bg-white sticky top-0 z-50 border-b border-gray-100">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-3xl font-serif text-gold tracking-widest flex items-center gap-2">
                 BRUNA <span class="text-luxury-black font-light text-2xl">YR</span>
            </div>
            
            <div class="hidden md:flex space-x-10 text-xs uppercase tracking-[0.2em] text-gray-800 font-semibold">
                <a href="#inicio" class="hover:text-gold transition-colors">Atelier</a>
                <a href="#catalogo" class="hover:text-gold transition-colors">Colecciones</a>
                <a href="#nosotros" class="hover:text-gold transition-colors">Nuestra Esencia</a>
            </div>

            <div class="flex items-center space-x-5">
                <button onclick="toggleAdmin()" class="text-gray-300 hover:text-gold transition" title="Gestión de Catálogo">
                    <i class="fas fa-gantt-chart text-lg"></i>
                </button>
                <a href="https://wa.me/584120466001" target="_blank" class="border border-gold text-gold px-6 py-2.5 text-xs font-semibold uppercase tracking-[0.2em] hover:bg-gold hover:text-white transition-all duration-300">
                    Solicitar Pedido
                </a>
            </div>
        </div>
    </nav>

    <header id="inicio" class="relative py-40 flex items-center justify-center text-center px-6 fade-in border-b border-gray-100">
        <div class="max-w-4xl">
            <p class="text-gold uppercase tracking-[0.4em] mb-6 text-xs font-bold">BY YUSNELY RAMIREZ</p>
            <h1 class="text-6xl md:text-8xl mb-8 font-serif leading-tight text-luxury-black">Arte en cada costura, <br>brillo en cada detalle.</h1>
            <p class="text-xl text-gray-600 mb-12 font-light max-w-2xl mx-auto">Una curaduría exclusiva de moda prêt-à-porter, joyería de autor y esencia de belleza, diseñada para la mujer que define su propio lujo.</p>
            <a href="#catalogo" class="bg-luxury-black text-white px-10 py-5 rounded-sm hover:bg-gold transition-colors uppercase text-xs tracking-[0.3em] font-bold shadow-sm">
                Descubrir las Colecciones
            </a>
        </div>
    </header>

    <section id="catalogo" class="py-24 container mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-5xl font-serif mb-8 text-luxury-black">El Catálogo</h2>
            <div class="flex flex-wrap justify-center gap-6" id="filters">
                <button onclick="filterProducts('Todos')" class="cat-btn text-gold font-semibold border-b border-gold px-3 py-1 uppercase text-xs tracking-widest">Todos</button>
                <button onclick="filterProducts('Ropa')" class="cat-btn text-gray-500 hover:text-gold border-b border-transparent hover:border-gold px-3 py-1 uppercase text-xs tracking-widest transition-all">Pret-à-Porter</button>
                <button onclick="filterProducts('Joyería')" class="cat-btn text-gray-500 hover:text-gold border-b border-transparent hover:border-gold px-3 py-1 uppercase text-xs tracking-widest transition-all">Joyería de Autor</button>
                <button onclick="filterProducts('Accesorios')" class="cat-btn text-gray-500 hover:text-gold border-b border-transparent hover:border-gold px-3 py-1 uppercase text-xs tracking-widest transition-all">Accesorios</button>
                <button onclick="filterProducts('Makeup')" class="cat-btn text-gray-500 hover:text-gold border-b border-transparent hover:border-gold px-3 py-1 uppercase text-xs tracking-widest transition-all">Beauty Essential</button>
            </div>
        </div>

        <div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16 items-start">
            </div>
    </section>

    <a href="https://wa.me/584120466001" target="_blank" class="fixed bottom-8 right-8 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-lg hover:scale-110 transition duration-300 flex items-center justify-center" title="Atención Personalizada">
        <i class="fab fa-whatsapp text-3xl"></i>
    </a>

    <footer id="nosotros" class="bg-luxury-black text-white py-20 text-center mt-10">
        <div class="container mx-auto px-6">
            <div class="text-4xl font-serif text-gold mb-6 tracking-widest">BRUNA YR</div>
            <p class="text-gray-400 text-base font-light mb-10 max-w-xl mx-auto">Donde la artesanía venezolana de Yusnely Ramirez se encuentra con la sofisticación global. Cada pieza es una declaración de estilo personal.</p>
            
            <div class="flex justify-center space-x-12 text-sm uppercase tracking-widest text-gray-500 mb-12">
                <span>WhatsApp: 0412-0466001</span>
                <a href="https://instagram.com/yrfashinclothes" target="_blank" class="hover:text-gold">Instagram: @yrfashinclothes</a>
            </div>
            
            <p class="text-gray-700 text-xs uppercase tracking-[0.3em]">&copy; 2024 BRUNA YR ATELIER. DERECHOS RESERVADOS.</p>
        </div>
    </footer>

    <div id="adminModal" class="admin-modal fixed inset-0 z-[100] p-6 items-center justify-center">
        <div class="bg-white rounded-sm w-full max-w-3xl p-10 relative shadow-2xl">
            <button onclick="toggleAdmin()" class="absolute top-6 right-6 text-gray-400 hover:text-red-500 text-xl transition"><i class="fas fa-times"></i></button>
            <h2 class="text-4xl font-serif mb-10 text-luxury-black border-b pb-4">Gestión del Atelier Digital</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <input type="text" id="p-name" placeholder="Nombre de la Pieza (Ej: Vestido Gala 'Ramirez')" class="admin-input">
                <input type="text" id="p-price" placeholder="Precio de Venta (Ej: $85.00)" class="admin-input">
                <select id="p-category" class="admin-input text-gray-500">
                    <option value="" disabled selected>Seleccionar Colección</option>
                    <option value="Ropa">Pret-à-Porter (Ropa)</option>
                    <option value="Joyería">Joyería de Autor</option>
                    <option value="Accesorios">Accesorios Premium</option>
                    <option value="Makeup">Beauty Essential (Makeup)</option>
                </select>
                <input type="text" id="p-image" placeholder="URL Directa de la Foto del Producto" class="admin-input text-sm">
            </div>
            <button onclick="addProduct()" class="w-full bg-luxury-black text-white p-4 rounded-sm font-bold uppercase text-xs tracking-widest hover:bg-gold transition shadow-md">
                Incorporar al Catálogo
            </button>
            <p class="text-xs text-gray-400 mt-6 text-center italic">Nota: Los productos nuevos se guardan exclusivamente en la memoria de este navegador.</p>
        </div>
    </div>

    <script>
        // Catálogo Inicial Premium (Ejemplos con mejores fotos de Unsplash)
        let products = JSON.parse(localStorage.getItem('bruna_premium_products')) || [
            { id: 1, name: "Vestido de Seda 'Yusnely'", category: "Ropa", price: "$120.00", image: "https://images.unsplash.com/photo-1595777457583-95e059d581b8?auto=format&fit=crop&w=600&q=80" },
            { id: 2, name: "Gargantilla Diamante 'Aura'", category: "Joyería", price: "$250.00", image: "https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&w=600&q=80" },
            { id: 3, name: "Paleta Sombras 'Midnight Gold'", category: "Makeup", price: "$45.00", image: "https://images.unsplash.com/photo-1512496115841-db0aaf4e8d28?auto=format&fit=crop&w=600&q=80" },
            { id: 4, name: "Bolso Estilo Tote 'Atelier'", category: "Accesorios", price: "$90.00", image: "https://images.unsplash.com/photo-1584916201218-f4242ceb4809?auto=format&fit=crop&w=600&q=80" },
            { id: 5, name: "Anillo Compromiso 'Eternity'", category: "Joyería", price: "$300.00", image: "https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&w=600&q=80" },
            { id: 6, name: "Blusa Lino 'Brisa'", category: "Ropa", price: "$65.00", image: "https://images.unsplash.com/photo-1581044777550-4cfa60707c03?auto=format&fit=crop&w=600&q=80" }
        ];

        function renderProducts(filter = 'Todos') {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = '';
            
            const filtered = filter === 'Todos' ? products : products.filter(p => p.category === filter);
            
            filtered.forEach((p, index) => {
                const waLink = `https://wa.me/584120466001?text=Hola,%20BRUNA%20YR!%20Deseo%20solicitar%20la%20pieza:%20${encodeURIComponent(p.name)}`;
                
                // Clases para crear el diseño asimétrico (masonry)
                let cardClasses = "product-card bg-white group overflow-hidden fade-in";
                if (index % 3 === 1) cardClasses += " md:mt-16"; // Columna central más abajo
                if (index % 3 === 2) cardClasses += " md:mt-8";  // Columna derecha un poco abajo

                grid.innerHTML += `
                    <div class="${cardClasses}">
                        <div class="aspect-[3/4] overflow-hidden bg-gray-50 border border-gray-100">
                            <img src="${p.image}" alt="${p.name}" class="w-full h-full object-cover">
                        </div>
                        <div class="pt-6 text-left">
                            <p class="text-[10px] text-gray-400 uppercase tracking-[0.3em] mb-1.5 font-semibold">${p.category}</p>
                            <h3 class="text-2xl font-serif text-luxury-black mb-1.5">${p.name}</h3>
                            <p class="text-base font-light text-gray-900 mb-5">${p.price}</p>
                            <a href="${waLink}" target="_blank" class="inline-block border border-luxury-black text-luxury-black px-6 py-3 text-[10px] font-bold uppercase tracking-[0.3em] hover:bg-luxury-black hover:text-white transition-all duration-300">
                                <i class="fab fa-whatsapp mr-1.5 text-xs"></i> Solicitar Pieza
                            </a>
                        </div>
                    </div>
                `;
            });
        }

        function filterProducts(category) {
            document.querySelectorAll('.cat-btn').forEach(btn => {
                btn.classList.remove('text-gold', 'border-gold', 'font-semibold');
                btn.classList.add('text-gray-500', 'border-transparent');
            });
            event.target.classList.add('text-gold', 'border-gold', 'font-semibold');
            event.target.classList.remove('text-gray-500', 'border-transparent');
            renderProducts(category);
        }

        // Funciones del Panel Administrador
        function toggleAdmin() {
            document.getElementById('adminModal').classList.toggle('active');
        }

        function addProduct() {
            const name = document.getElementById('p-name').value;
            const price = document.getElementById('p-price').value;
            const category = document.getElementById('p-category').value;
            const image = document.getElementById('p-image').value || 'https://via.placeholder.com/600x800?text=Foto+Atelier+BRUNA+YR';

            if(!name || !price || !category) {
                alert("Por favor completa el nombre, precio y colección.");
                return;
            }

            products.push({ id: Date.now(), name, price, category, image });
            localStorage.setItem('bruna_premium_products', JSON.stringify(products)); // Guarda en memoria
            
            document.getElementById('p-name').value = '';
            document.getElementById('p-price').value = '';
            document.getElementById('p-image').value = '';
            document.getElementById('p-category').selectedIndex = 0;
            
            toggleAdmin();
            renderProducts();
            alert("¡La nueva pieza ha sido incorporada con éxito!");
        }

        // Cargar productos al iniciar
        window.onload = () => renderProducts();
    </script>
</body>
</html>